generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InterviewDimension {
  joy
  fulfillment
  reflection
  improvement
  gratitude
}

enum InterviewSessionStatus {
  active
  paused
  completed
  abandoned
}

enum InterviewRole {
  user
  assistant
  system
}

enum InputMode {
  text
  voice
}

enum JoyInterviewStage {
  collect_event
  probe_reason
  probe_pattern
  wrap_up
  finalize
}

enum JoyEntrySource {
  ai_draft_direct
  ai_draft_edited
}

enum JoyEntryStatus {
  draft
  saved
}

enum DailyJournalStatus {
  draft
  saved
}

enum InterviewEventStatus {
  active
  ready_for_choice
  completed
}

enum AIRequestStage {
  transcribe
  extract
  generate
  portrait_synthesis
}

enum MemorySourceType {
  ai_extracted
  user_added
}

model User {
  id          String             @id @default(cuid())
  createdAt   DateTime           @default(now())
  settings    UserSettings?
  sessions    InterviewSession[]
  joyEntries  JoyEntry[]
  dailyJournalEntries DailyJournalEntry[]
  dailyHappinessScores DailyHappinessScore[]
  memoryFacts MemoryFact[]
  portraitSnapshots PortraitSnapshot[]
}

model UserSettings {
  id                            String   @id @default(cuid())
  userId                        String   @unique
  memoryEnabled                 Boolean  @default(false)
  transcriptAutoFallbackEnabled Boolean  @default(true)
  timezone                      String   @default("Asia/Shanghai")
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  user                          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterviewSession {
  id                    String                 @id @default(cuid())
  userId                String
  dimension             InterviewDimension
  status                InterviewSessionStatus @default(active)
  stage                 JoyInterviewStage      @default(collect_event)
  activeEventId         String?
  turnCount             Int                    @default(0)
  entryDate             DateTime
  startedAt             DateTime               @default(now())
  pausedAt              DateTime?
  completedAt           DateTime?
  lastAssistantQuestion String?
  draftSummary          String?
  finalEntryId          String?                @unique
  activeEvent           InterviewEvent?        @relation("ActiveInterviewEvent", fields: [activeEventId], references: [id], onDelete: SetNull)
  events                InterviewEvent[]       @relation("SessionInterviewEvents")
  messages              InterviewMessage[]
  snapshots             JoyInterviewSnapshot[]
  aiRequestLogs         AIRequestLog[]
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  joyEntry              JoyEntry?              @relation("SessionJoyEntry")

  @@index([userId, status])
}

model InterviewEvent {
  id                       String               @id @default(cuid())
  sessionId                String
  sequence                 Int
  status                   InterviewEventStatus @default(active)
  stage                    JoyInterviewStage    @default(collect_event)
  explorationRound         Int                  @default(1)
  coveredLenses            String[]             @default([])
  roundCoveredLenses       String[]             @default([])
  roundMeaningfulReplyCount Int                 @default(0)
  totalMeaningfulReplyCount Int                 @default(0)
  startMessageSequence     Int                  @default(0)
  event                    String?
  feeling                  String?
  whyItMattered            String?
  happinessType            String?
  selfPattern              String?
  snapshotData             Json?
  progressData             Json?
  confidence               Float?
  missingSlots             String[]             @default([])
  draftSummary             String?
  startedAt                DateTime             @default(now())
  completedAt              DateTime?
  session                  InterviewSession     @relation("SessionInterviewEvents", fields: [sessionId], references: [id], onDelete: Cascade)
  activeForSession         InterviewSession[]   @relation("ActiveInterviewEvent")

  @@unique([sessionId, sequence])
  @@index([sessionId, status])
}

model InterviewMessage {
  id        String           @id @default(cuid())
  sessionId String
  role      InterviewRole
  inputMode InputMode?
  content   String
  sequence  Int
  createdAt DateTime         @default(now())
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@index([sessionId, createdAt])
}

model JoyInterviewSnapshot {
  id              String           @id @default(cuid())
  sessionId       String
  version         Int
  event           String?
  feeling         String?
  whyItMattered   String?
  happinessType   String?
  selfPattern     String?
  confidence      Float?
  missingSlots    String[]
  createdAt       DateTime         @default(now())
  session         InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, version])
  @@index([sessionId, createdAt])
}

model JoyEntry {
  id              String         @id @default(cuid())
  userId          String
  sessionId       String         @unique
  date            DateTime
  title           String
  content         String
  event           String?
  feeling         String?
  whyItMattered   String?
  happinessType   String?
  selfPattern     String?
  tags            String[]
  payload         Json?
  eventBlocks     Json?
  source          JoyEntrySource
  status          JoyEntryStatus @default(draft)
  linkedSessionIds String[]      @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  savedAt         DateTime?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  session         InterviewSession @relation("SessionJoyEntry", fields: [sessionId], references: [id], onDelete: Cascade)
}

model DailyJournalEntry {
  id               String             @id @default(cuid())
  userId           String
  date             DateTime
  title            String
  content          String
  status           DailyJournalStatus @default(draft)
  sourceEntryIds   String[]
  sourceSessionIds String[]
  sourceSignature  String
  sourceUpdatedAt  DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  savedAt          DateTime?
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, status])
}

model DailyHappinessScore {
  id                   String   @id @default(cuid())
  userId               String
  date                 DateTime
  meaningScore         Int
  healthScore          Int
  virtueScore          Int
  autonomyScore        Int
  interestScore        Int
  skillScore           Int
  relationshipScore    Int
  livingConditionScore Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model MemoryFact {
  id                 String             @id @default(cuid())
  userId             String
  dimension          InterviewDimension
  kind               String
  topicTags          String[]           @default([])
  summary            String
  embedding          Unsupported("vector(2048)")?
  sourceType         MemorySourceType   @default(ai_extracted)
  confidence         Float              @default(0)
  evidenceEntryIds   String[]
  evidenceSessionIds String[]           @default([])
  deletedAt          DateTime?
  lastUsedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dimension, kind])
  @@index([userId, deletedAt])
}

model AIRequestLog {
  id        String          @id @default(cuid())
  sessionId String
  stage     AIRequestStage
  provider  String
  latencyMs Int?
  success   Boolean
  errorCode String?
  createdAt DateTime        @default(now())
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, stage])
}

model PortraitSnapshot {
  id               String   @id @default(cuid())
  userId           String
  summary          String
  dimensionInsights Json
  factCount        Int
  dataRangeMonths  Int      @default(3)
  generatedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
