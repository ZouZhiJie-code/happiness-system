# Local development defaults.
# For the hosted Vercel lane, copy `.env.preview.example` or `.env.production.example`
# and fill the real hosted values there before setting them in the platform UI.
DATABASE_URL="postgresql://zouzhijie@localhost:5432/happiness_system_codex?schema=public"
DIRECT_URL="postgresql://zouzhijie@localhost:5432/happiness_system_codex?schema=public"
AI_RUNTIME_CONFIG_SECRET=""
CRON_SECRET=""
AI_PROVIDER="volcengine-ark"
# DeepSeek and other hosted chat models can be used through Volcengine Ark by filling the key and model below.
VOLCENGINE_ARK_API_KEY=""
VOLCENGINE_ARK_MODEL=""
VOLCENGINE_ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
# Embedding endpoint for vector memory (doubao-embedding model)
VOLCENGINE_ARK_EMBEDDING_ENDPOINT_ID=""
APP_URL="http://localhost:3000"
ADMIN_USERNAMES=""
ACCEPTANCE_ADMIN_USERNAME="acceptance_admin"
ACCEPTANCE_ADMIN_PASSWORD="Acceptance-Only-2026"
ACCEPTANCE_LOGIN_TOKEN="local-ai-quality-acceptance"
